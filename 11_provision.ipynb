   "source": [
    "import pandas as pd\n",
    "\n",
    "# -------------------------------\n",
    "# FUNCIONES DE UTILIDAD\n",
    "# -------------------------------\n",
    "def normalize_column(df, column):\n",
    "    df[column] = df[column].astype(str).str.strip().fillna(\"\")\n",
    "    return df\n",
    "\n",
    "def normalize_columns(df, columns):\n",
    "    for col in columns:\n",
    "        df = normalize_column(df, col)\n",
    "    return df\n",
    "\n",
    "# -------------------------------\n",
    "# 0. CARGA DE DATOS\n",
    "# -------------------------------\n",
    "base_path_1 = r'C:\\Users\\fgomez\\OneDrive - Reckitt\\Documents 1\\SAP\\SAP GUI'\n",
    "\n",
    "cierreF = [\n",
    "    fr'{base_path_1}\\AR02_IcADR_F.XLSX',\n",
    "    fr'{base_path_1}\\AR06_IcADR_F.XLSX'\n",
    "]
",
    "\n",
    "boreal = 'Boreal Provision.xlsx'\n",
    "maestro_file = fr'{base_path_1}/MAESTRO SAP.xlsm'\n",
    "tarifario_file = 'Tarifario_macro.xlsm'\n",
    "\n",
    "filtro_a = [\n",
    "    'LR number', 'Billing date', 'Plant', 'Ship to party', 'Ship to party name',\n",
    "    'Reference Document number', 'Material', 'Batch number', \n",
    "    'Billed quantity (Base UoM)', 'Sales UoM', 'Billing document', \n",
    "    'Accounting document number', 'Reference'\n",
    "]
",
    "\n",
    "filtro_b = [\n",
    "    'Estado', 'WM.OutboundDelivery.shipmentCode', 'Transporte', 'Código', \n",
    "    'Transportista', 'Tipo unidad', 'Tipo trans.', 'Despacho esperado', \n",
    "    'Dirección', 'Ciudad', 'Packs totales', 'Est. picks ', 'Est. puros', 'Peso total kg'\n",
    "]
",
    "\n",
    "rename_dict = {\n",
    "    'WM.OutboundDelivery.shipmentCode': 'N_VIAJE_1',\n",
    "    'Transporte': 'N_VIAJE_2',\n",
    "    'Código': 'OBD',\n",
    "    'Tipo trans.': 'CV',\n",
    "    'Dirección': 'SHIPTO'\n",
    "}\n",
    "\n",
    "# -------------------------------\n",
    "# 1. CARGAR BILLING\n",
    "# -------------------------------\n",
    "def load_billing(files, columns):\n",
    "    df_list = [pd.read_excel(f) for f in files]\n",
    "    billing = pd.concat(df_list, ignore_index=True)\n",
    "    billing = billing[columns]\n",
    "    billing = billing[billing['Ship to party'] != '1000078394']\n",
    "    \n",
    "    billing_pivot = pd.pivot_table(\n",
    "        billing,\n",
    "        index=['LR number', 'Ship to party name', 'Ship to party', 'Reference Document number'],\n",
    "        values=['Billed quantity (Base UoM)'],\n",
    "        aggfunc='sum',\n",
    "        fill_value=0\n",
    "    ).reset_index()\n",
    "    \n",
    "    billing_pivot = normalize_columns(billing_pivot, ['Reference Document number', 'Ship to party'])\n",
    "    return billing_pivot\n",
    "\n",
    "# -------------------------------\n",
    "# 2. CARGAR RUTEADOS\n",
    "# -------------------------------\n",
    "def load_ruteados(file, columns, rename_dict):\n",
    "    df = pd.read_excel(file, skiprows=1)\n",
    "    df = df[columns].rename(columns=rename_dict)\n",
    "    df['Transportista'] = df['Transportista'].astype(str).str[5:]\n",
    "    df['Tipo unidad'] = df['Tipo unidad'].astype(str).str[3:]\n",
    "    df = df[df['Estado'] == 'Despachado']\n",
    "    \n",
    "    df_pivot = pd.pivot_table(\n",
    "        df,\n",
    "        index=['CV', 'N_VIAJE_1', 'N_VIAJE_2','OBD', 'Tipo unidad', 'SHIPTO', 'Transportista'],\n",
    "        values=['Packs totales', 'Est. picks ', 'Est. puros', 'Peso total kg'],\n",
    "        aggfunc='sum',\n",
    "        fill_value=0\n",
    "    ).reset_index()\n",
    "    \n",
    "    df_pivot = normalize_columns(df_pivot, ['Transportista'])\n",
    "    return df_pivot\n",
    "\n",
    "# -------------------------------\n",
    "# 3. CARGAR MAESTRO DE CLIENTES\n",
    "# -------------------------------\n",
    "def load_maestro(path):\n",
    "    df = pd.read_excel(path, sheet_name='Customer', skiprows=3, usecols='B:S')\n",
    "    df['SHIP TO'] = df['SHIP TO'].apply(lambda x: str(int(x)) if isinstance(x, float) and x.is_integer() else str(x))\n",
    "    \n",
    "    df_pivot = df.pivot_table(\n",
    "        index=['SHIP TO', 'Customer number of business partner', 'Provincia', 'RUTA', 'TRANSPORT ZONE', 'Coordenadas','CIUDAD'],\n",
    "        values=['Customer Number'],\n",
    "        aggfunc='count',\n",
    "        fill_value=0\n",
    "    ).reset_index()\n",
    "    \n",
    "    return df_pivot\n",
    "\n",
    "# -------------------------------\n",
    "# 4. CARGAR TARIFARIO\n",
    "# -------------------------------\n",
    "def load_tarifario(path):\n",
    "    df = pd.read_excel(path, sheet_name=\"Tarifario\", skiprows=9)\n",
    "    df = normalize_columns(df, ['CARRIER', 'TRANSPORT ZONE'])\n",
    "    return df\n",
    "\n",
    "# -------------------------------\n",
    "# 5. MERGE RUTEADOS + BILLING\n",
    "# -------------------------------\n",
    "def merge_ruteados_billing(ruteados, billing):\n",
    "    ruteados = normalize_columns(ruteados, ['OBD'])\n",
    "    billing = normalize_columns(billing, ['Reference Document number'])\n",
    "    \n",
    "    return pd.merge(\n",
    "        ruteados,\n",
    "        billing,\n",
    "        left_on='OBD',\n",
    "        right_on='Reference Document number',\n",
    "        how='left'\n",
    "    )\n",
    "\n",
    "# -------------------------------\n",
    "# 6. MERGE CON MAESTRO CLIENTES\n",
    "# -------------------------------\n",
    "def merge_with_mc(df, mc):\n",
    "    df = normalize_columns(df, ['Ship to party'])\n",
    "    return pd.merge(\n",
    "        df,\n",
    "        mc[['SHIP TO', 'TRANSPORT ZONE', 'CIUDAD']],\n",
    "        left_on='Ship to party',\n",
    "        right_on='SHIP TO',\n",
    "        how='left'\n",
    "    ).drop(columns=['SHIP TO'])\n",
    "\n",
    "# -------------------------------\n",
    "# 7. ASIGNAR TARIFA POR COMBINACIÓN EXACTA\n",
    "# -------------------------------\n",
    "def asignar_tarifa_simple(df_viajes, tarifario):\n",
    "    tarifas = []\n",
    "\n",
    "    for _, row in df_viajes.iterrows():\n",
    "        tipo_viaje = str(row['CV']).strip().upper()\n",
    "        transportista = str(row['Transportista']).strip().upper()\n",
    "        zona = str(row['TRANSPORT ZONE']).strip().upper()\n",
    "        tipo_unidad = str(row['Tipo unidad']).strip().upper()\n",
    "        peso_total = row['Peso total kg']\n",
    "        tarifa = None  # Inicializar tarifa para cada fila\n",
    "\n",
    "        # --- LÓGICA PARA VIAJE SIMPLE ---\n",
    "        if tipo_viaje == 'SIMPLE':\n",
    "            filtro = tarifario[\n",
    "                (tarifario['CARRIER'].str.upper() == transportista) &\n",
    "                (tarifario['TRANSPORT ZONE'].str.upper() == zona)\n",
    "            ]\n",
    "\n",
    "            if not filtro.empty and tipo_unidad in filtro.columns:\n",
    "                tarifa = filtro.iloc[0][tipo_unidad]\n",
    "\n",
    "        # --- LÓGICA PARA ANDREANI ---\n",
    "        elif tipo_viaje == 'DISTRIBUCIÓN - TRONCAL' and transportista == 'ANDREANI LOGISTICA S.A.':\n",
    "            filtro = tarifario[\n",
    "                (tarifario['CARRIER'].str.upper() == transportista) &\n",
    "                (tarifario['TRANSPORT ZONE'].str.upper() == zona)\n",
    "            ]\n",
    "\n",
    "            if not filtro.empty:\n",
    "                tarifa_base = filtro.iloc[0].get('1s')\n",
    "                tarifa_kg_excedente = filtro.iloc[0].get('X KG')\n",
    "\n",
    "                if pd.notna(tarifa_base) and pd.notna(tarifa_kg_excedente):\n",
    "                    if peso_total <= 900:\n",
    "                        tarifa = tarifa_base\n",
    "                    else:\n",
    "                        tarifa = tarifa_base + (peso_total - 900) * tarifa_kg_excedente\n",
    "\n",
    "        # --- LÓGICA PARA GIAMPAOLETTI ---\n",
    "        elif tipo_viaje == 'DISTRIBUCIÓN - TRONCAL' and transportista == 'GIAMPAOLETTI BUOSI S.A.':\n",
    "            filtro = tarifario[\n",
    "                (tarifario['CARRIER'].str.upper() == transportista) &\n",
    "                (tarifario['TRANSPORT ZONE'].str.upper() == zona)\n",
    "            ]\n",
    "\n",
    "            if not filtro.empty:\n",
    "                tarifa_base = filtro.iloc[0].get('1s')  # Columna O\n",
    "                tarifa_kg = filtro.iloc[0].get('X KG')  # Columna T\n",
    "\n",
    "                if pd.notna(tarifa_base) and pd.notna(tarifa_kg):\n",
    "                    tarifa = tarifa_base + (peso_total * tarifa_kg)\n",
    "\n",
    "        tarifas.append(tarifa)\n",
    "\n",
    "    df_viajes['Tarifa'] = tarifas\n",
    "    return df_viajes\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "# -------------------------------\n",
    "# MAIN SCRIPT\n",
    "# -------------------------------\n",
    "if __name__ == \"__main__\":\n",
    "    billing_b = load_billing(cierreF, filtro_a)\n",
    "    ruteados = load_ruteados(boreal, filtro_b, rename_dict)\n",
    "    mc = load_maestro(maestro_file)\n",
    "    tarifario = load_tarifario(tarifario_file)\n",
    "    \n",
    "    # Merge 1\n",
    "    df_step1 = merge_ruteados_billing(ruteados, billing_b)\n",
    "    \n",
    "    # Merge 2\n",
    "    df_step2 = merge_with_mc(df_step1, mc)\n",
    "\n",
    "    # Pivot intermedio\n",
    "    df_step2_pivot = df_step2.pivot_table(\n",
    "        index=['CV' ,'Transportista', 'N_VIAJE_1', 'N_VIAJE_2', 'SHIPTO', 'Tipo unidad', 'Ship to party', 'TRANSPORT ZONE', 'CIUDAD'],\n",
    "        values=['Packs totales', 'Est. picks ', 'Est. puros', 'Peso total kg','OBD'],\n",
    "        aggfunc={\n",
    "            'OBD':'count',\n",
    "            'Packs totales': 'sum',\n",
    "            'Est. picks ': 'sum',\n",
    "            'Est. puros': 'sum',\n",
    "            'Peso total kg': 'sum'\n",
    "        },\n",
    "        fill_value=0\n",
    "    ).reset_index()\n",
    "\n",
    "    df_step2_pivot.to_excel('pivot_intermedio.xlsx', index=False)\n",
    "    print(\"📊 Pivot intermedio guardado como 'pivot_intermedio.xlsx'\")\n",
    "\n",
    "    # Asignar tarifa por combinación exacta\n",
    "    df_final = asignar_tarifa_simple(df_step2_pivot, tarifario)\n",
    "\n",
    "    \n",
    "    # Mostrar preview final\n",
    "    cols_mostrar = ['OBD', 'Ship to party', \n",
    "                    'TRANSPORT ZONE', 'CIUDAD', 'Transportista', 'CV', 'Tipo unidad', 'Tarifa']\n",
    "    print(df_final[cols_mostrar].head())\n",
    "    \n",
    "    # Guardar en Excel\n",
    "    df_final.to_excel('resultado_final.xlsx', index=False)\n",
    "    print(\"✅ Archivo 'resultado_final.xlsx' generado correctamente.\")\n"
   ]
  },
